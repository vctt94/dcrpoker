<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Poker Server Status</title>
    <style>
      :root { --bg:#0f172a; --panel:#111827; --text:#e5e7eb; --muted:#9ca3af; --accent:#22c55e; --warn:#f59e0b; --bad:#ef4444; }
      body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, sans-serif; background:var(--bg); color:var(--text); }
      .wrap { max-width: 980px; margin: 32px auto; padding: 0 16px; }
      .grid { display:grid; grid-template-columns: repeat(auto-fill,minmax(220px,1fr)); gap:12px; margin: 16px 0 24px; }
      .card { background:var(--panel); border-radius:10px; padding:14px 16px; box-shadow: 0 2px 10px rgba(0,0,0,.25); }
      .k { font-size:12px; color:var(--muted); text-transform:uppercase; letter-spacing:.06em}
      .v { font-size:22px; font-weight:600; margin-top:6px; }
      table { width:100%; border-collapse: collapse; }
      th, td { padding:10px 8px; border-bottom: 1px solid #1f2937; text-align:left; }
      th { color:var(--muted); font-weight:500; }
      .ok { color: var(--accent); }
      .warn { color: var(--warn); }
      .bad { color: var(--bad); }
      .header { display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:10px; }
      .small { color: var(--muted); font-size: 12px; }
      a { color:#60a5fa; text-decoration:none; }
      a:hover { text-decoration:underline; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="header">
        <h1 style="margin:0">Poker Server Status</h1>
        <div class="small">Generated at {{ .GeneratedAt.Format "2006-01-02 15:04:05 MST" }}</div>
      </div>

      <div class="grid">
        <div class="card"><div class="k">Tables</div><div class="v">{{ .Summary.Tables }}</div></div>
        <div class="card"><div class="k">Users (total)</div><div class="v">{{ .Summary.Users }}</div></div>
        <div class="card"><div class="k">Users (distinct)</div><div class="v">{{ .Summary.DistinctUsers }}</div></div>
        <div class="card"><div class="k">Online Users</div><div class="v">{{ .Summary.OnlineUsers }}</div></div>
        <div class="card"><div class="k">Ready Users</div><div class="v">{{ .Summary.ReadyUsers }}</div></div>
        <div class="card"><div class="k">Active Games</div><div class="v">{{ .Summary.GamesActive }}</div></div>
        <div class="card"><div class="k">Event Queue</div><div class="v">{{ .QueueDepth }} / {{ .QueueCapacity }}</div></div>
        <div class="card"><div class="k">Event Drops</div><div class="v">{{ .EventDrops }}</div></div>
        <div class="card"><div class="k">Goroutines</div><div class="v">{{ .GoRoutines }}</div></div>
      </div>

      <div class="card">
        <div class="k" style="margin-bottom:8px">Tables</div>
        <table>
          <thead>
            <tr>
              <th>Table ID</th>
              <th>Users</th>
              <th>Online</th>
              <th>Ready</th>
              <th>All Ready</th>
              <th>Active</th>
            </tr>
          </thead>
          <tbody>
          {{- range .Summary.TablesInfo }}
            <tr>
              <td><code>{{ .ID }}</code></td>
              <td>{{ .Users }}</td>
              <td>{{ .OnlineUsers }}</td>
              <td>{{ .ReadyUsers }}</td>
              <td>{{ if .AllReady }}<span class="ok">Yes</span>{{ else }}<span class="warn">No</span>{{ end }}</td>
              <td>{{ if .GameActive }}<span class="ok">Active</span>{{ else }}<span class="bad">Idle</span>{{ end }}</td>
            </tr>
          {{- end }}
          </tbody>
        </table>
        <div class="small" style="margin-top:8px">Prometheus metrics available at <a href="/metrics">/metrics</a></div>
      </div>
    </div>
  </body>
  </html>

